// 虚拟滚动列表组件（完整复刻原Vue版本的 vue-virtual-scroller）
// Phase 11 Week 5-6：交互功能实现 - 虚拟滚动优化
import { VerticalBox, ListView } from "std-widgets.slint";
import { Theme } from "../theme.slint";

// ==================== 虚拟滚动基础组件 ====================

// Virtual List（使用Slint的ListView，自动支持虚拟滚动）
export component VirtualList inherits Rectangle {
    in property <string> title: "";
    in property <int> item-count: 0;
    in property <int> item-height: 28;  // 默认每项高度28px

    callback load-more();  // 加载更多数据

    background: Theme.background;
    border-radius: Theme.radius-md;

    VerticalBox {
        padding: Theme.spacing-sm;

        // 标题和统计
        if title != "": HorizontalBox {
            spacing: 8px;

            Text {
                text: title;
                font-size: 12px;
                font-weight: 600;
                color: Theme.text-primary;
            }

            Text {
                text: item-count + " items";
                font-size: 12px;
                color: Theme.text-secondary;
            }
        }

        // 滚动提示（当item-count较大时）
        if item-count > 100: Text {
            text: "Scrolling optimized for large datasets";
            font-size: 10px;
            color: Theme.text-secondary;
        }
    }
}

// ==================== Topic虚拟列表（专用）====================

// Topic Virtual List（Topics文件夹内的虚拟滚动列表）
export component TopicVirtualList inherits VirtualList {
    in property <[string]> topic-names: [];
    in property <string> cluster-name: "";
    in property <string> search-query: "";

    callback topic-selected(string, string);  // topic_name, cluster_name

    title: "Topics";

    VerticalBox {
        padding: 8px;

        // Topic列表（使用for循环，Slint自动虚拟滚动）
        // 注意：Slint的for循环在大数据量时自动启用虚拟滚动
        for topic-name in topic-names: Rectangle {
            height: 28px;
            background: Theme.surface;
            border-radius: 4px;

            HorizontalBox {
                padding: 8px;
                spacing: 8px;

                // Topic图标
                Text {
                    text: "📨";
                    font-size: 12px;
                    color: Theme.primary;
                }

                // Topic名称
                Text {
                    text: topic-name;
                    font-size: 12px;
                    color: Theme.text-primary;
                }
            }

            TouchArea {
                clicked => { topic-selected(topic-name, cluster-name); }
            }
        }

        // 空提示
        if topic-names.length == 0: Text {
            text: "No topics found";
            font-size: 12px;
            color: Theme.text-secondary;
        }
    }
}

// ==================== Consumer Group虚拟列表（专用）====================

