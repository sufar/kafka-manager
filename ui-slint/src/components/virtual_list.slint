// ==================== Message虚拟列表（专用）====================

// Message Virtual List（Messages页面的虚拟滚动）
export component MessageVirtualList inherits VirtualList {
    in property <[string]> message-keys: [];  // Message Key列表
    in property <string> cluster-name: "";
    in property <string> topic-name: "";

    callback message-selected(string);

    title: "Messages";

    VerticalBox {
        padding: 8px;

        // Message列表
        for message-key in message-keys: Rectangle {
            height: 32px;
            background: Theme.surface;
            border-radius: 4px;

            HorizontalBox {
                padding: 8px;
                spacing: 8px;

                // Message图标
                Text {
                    text: "✉️";
                    font-size: 12px;
                    color: Theme.primary;
                }

                // Message Key
                Text {
                    text: message-key;
                    font-size: 12px;
                    color: Theme.text-primary;
                }
            }

            TouchArea {
                clicked => { message-selected(message-key); }
            }
        }
    }
}

// ==================== 滚动性能优化提示 ====================

// Performance Hint（性能提示）
export component PerformanceHint inherits Rectangle {
    in property <int> total-items: 0;
    in property <int> rendered-items: 0;  // 实际渲染的数量（虚拟滚动）

    height: 40px;
    background: Theme.background;
    border-radius: 4px;

    HorizontalBox {
        padding: 8px;
        spacing: 8px;

        Text {
            text: "💡";
            font-size: 14px;
            color: Theme.warning;
        }

        Text {
            text: "Virtual scrolling: " + rendered-items + " of " + total-items + " items rendered";
            font-size: 12px;
            color: Theme.text-secondary;
        }
    }
}

// ==================== 批量加载优化 ====================

// Batch Load Hint（批量加载提示）
export component BatchLoadHint inherits Rectangle {
    in property <int> loaded-count: 0;
    in property <int> batch-size: 50;

    height: 40px;
    background: Theme.background;
    border-radius: 4px;

    HorizontalBox {
        padding: 8px;
        spacing: 8px;

        Text {
            text: "📊";
            font-size: 14px;
            color: Theme.primary;
        }

        Text {
            text: "Loaded " + loaded-count + " items (batch size: " + batch-size + ")";
            font-size: 12px;
            color: Theme.text-secondary;
        }
    }
}