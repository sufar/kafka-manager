// 卡片组件（简化版本 - 移除glass和gradient-border）
// Phase 11 Week 11-12：样式优化 - 简化Card设计
import { Theme } from "../theme.slint";

// ==================== 基础卡片组件 ====================

// 基础卡片（简化版）
export component Card inherits Rectangle {
    // 卡片内容
    in property <string> title: "";
    in property <string> subtitle: "";
    in property <string> icon: "";

    // 回调
    callback clicked();

    // 卡片基础样式（简化）
    background: Theme.surface;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border;

    VerticalBox {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-sm;

        // 标题区域
        HorizontalBox {
            spacing: Theme.spacing-sm;

            // 图标（Unicode替代SVG）
            if icon != "": Text {
                text: icon;
                font-size: 24px;
                color: Theme.primary;
            }

            VerticalBox {
                alignment: start;

                // 标题
                if title != "": Text {
                    text: title;
                    font-size: 16px;
                    font-weight: 600;
                    color: Theme.text-primary;
                }

                // 副标题
                if subtitle != "": Text {
                    text: subtitle;
                    font-size: 12px;
                    color: Theme.text-secondary;
                }
            }
        }

        // 内容区域（占位符）
        Rectangle {
            vertical-stretch: 1;
            background: transparent;
        }
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

// ==================== 集群卡片（专用）====================

// Cluster Card（用于 ClustersView）
export component ClusterCard inherits Rectangle {
    in property <string> cluster-name: "";
    in property <string> bootstrap-servers: "";
    in property <string> status: "connected";  // "connected" / "disconnected" / "error"
    in property <int> topics-count: 0;
    in property <int> partitions-count: 0;
    in property <bool> selected: false;

    callback edit-clicked();
    callback delete-clicked();
    callback connect-clicked();

    // 简化的卡片样式
    background: selected ? Theme.primary-hover : Theme.surface;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: selected ? Theme.primary : Theme.border;

    VerticalBox {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-sm;

        // 标题区域
        HorizontalBox {
            spacing: Theme.spacing-sm;

            // 集群图标
            Text {
                text: "📊";
                font-size: 24px;
                color: Theme.primary;
            }

            VerticalBox {
                alignment: start;

                // 集群名称
                Text {
                    text: cluster-name;
                    font-size: 16px;
                    font-weight: 600;
                    color: Theme.text-primary;
                }

                // Bootstrap Servers
                Text {
                    text: bootstrap-servers;
                    font-size: 12px;
                    color: Theme.text-secondary;
                }
            }
        }

        // 统计信息
        HorizontalBox {
            spacing: Theme.spacing-md;

            Text {
                text: "📁 " + topics-count + " Topics";
                font-size: 12px;
                color: Theme.text-secondary;
            }

            Text {
                text: "📊 " + partitions-count + " Partitions";
                font-size: 12px;
                color: Theme.text-secondary;
            }
        }

        // 操作按钮
        HorizontalBox {
            spacing: Theme.spacing-sm;

            // 编辑按钮
            Rectangle {
                width: 60px;
                height: 30px;
                background: Theme.primary;
                border-radius: 4px;

                Text {
                    text: "✏️ Edit";
                    font-size: 12px;
                    color: white;
                }

                TouchArea {
                    clicked => { edit-clicked(); }
                }
            }

            // 删除按钮
            Rectangle {
                width: 60px;
                height: 30px;
                background: Theme.error;
                border-radius: 4px;

                Text {
                    text: "🗑️ Delete";
                    font-size: 12px;
                    color: white;
                }

                TouchArea {
                    clicked => { delete-clicked(); }
                }
            }

            // 连接按钮
            Rectangle {
                width: 80px;
                height: 30px;
                background: status == "connected" ? Theme.success : Theme.warning;
                border-radius: 4px;

                Text {
                    text: status == "connected" ? "✓ Connected" : "🔄 Connect";
                    font-size: 12px;
                    color: white;
                }

                TouchArea {
                    clicked => { connect-clicked(); }
                }
            }
        }
    }
}

// ==================== Topic卡片（专用）====================

// Topic Card（用于 TopicsView）
export component TopicCard inherits Rectangle {
    in property <string> topic-name: "";
    in property <string> cluster-name: "";
    in property <int> partitions-count: 0;
    in property <int> replication-factor: 1;
    in property <bool> is-internal: false;
    in property <bool> selected: false;

    callback view-messages-clicked();
    callback view-config-clicked();

    background: selected ? Theme.primary-hover : Theme.surface;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: selected ? Theme.primary : Theme.border;

    VerticalBox {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-sm;

        // 标题区域
        HorizontalBox {
            spacing: Theme.spacing-sm;

            // Topic图标
            Text {
                text: is-internal ? "🔒" : "📨";
                font-size: 24px;
                color: Theme.primary;
            }

            VerticalBox {
                alignment: start;

                // Topic名称
                Text {
                    text: topic-name;
                    font-size: 16px;
                    font-weight: 600;
                    color: Theme.text-primary;
                }

                // 集群名称
                Text {
                    text: cluster-name;
                    font-size: 12px;
                    color: Theme.text-secondary;
                }
            }
        }

        // 统计信息
        HorizontalBox {
            spacing: Theme.spacing-md;

            Text {
                text: "📁 " + partitions-count + " Partitions";
                font-size: 12px;
                color: Theme.text-secondary;
            }

            Text {
                text: "🔄 " + replication-factor + " Replicas";
                font-size: 12px;
                color: Theme.text-secondary;
            }

            // Internal标记
            if is-internal: Rectangle {
                width: 60px;
                height: 20px;
                background: Theme.warning;
                border-radius: 4px;

                Text {
                    text: "Internal";
                    font-size: 10px;
                    color: white;
                }
            }
        }

        // 操作按钮
        HorizontalBox {
            spacing: Theme.spacing-sm;

            // 查看消息按钮
            Rectangle {
                width: 80px;
                height: 30px;
                background: Theme.primary;
                border-radius: 4px;

                Text {
                    text: "📨 Messages";
                    font-size: 12px;
                    color: white;
                }

                TouchArea {
                    clicked => { view-messages-clicked(); }
                }
            }

            // 查看配置按钮
            Rectangle {
                width: 80px;
                height: 30px;
                background: Theme.background;
                border-radius: 4px;

                Text {
                    text: "⚙️ Config";
                    font-size: 12px;
                    color: Theme.text-primary;
                }

                TouchArea {
                    clicked => { view-config-clicked(); }
                }
            }
        }
    }
}