// ClustersView完整复刻（Phase 11 Week 7-8：页面复刻）
// 完整复刻原Vue版本的 ClustersView.vue
import { Button, VerticalBox, HorizontalBox, ComboBox, LineEdit } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { ClusterCard } from "../components/card.slint";
import { Badge } from "../components/badge.slint";
import { Modal, CreateClusterModal } from "../components/modal.slint";
import { Toast } from "../components/toast.slint";

// ==================== ClustersView组件 ====================

export component ClustersView inherits Rectangle {
    // 数据属性
    in property <[string]> cluster-names: [];  // 集群名称列表
    in property <[string]> group-names: [];  // 分组名称列表
    in property <string> selected-group: "";  // 选中的分组
    in property <bool> loading: false;
    in property <string> error: "";

    // 国际化字符串
    in property <string> i18n-title: "Clusters";
    in property <string> i18n-description: "Manage your Kafka clusters";
    in property <string> i18n-add-group: "Manage Groups";
    in property <string> i18n-add-cluster: "Add Cluster";
    in property <string> i18n-all: "All";
    in property <string> i18n-group: "Group";
    in property <string> i18n-loading: "Loading...";
    in property <string> i18n-connection-error: "Connection Error";
    in property <string> i18n-retry: "Retry";
    in property <string> i18n-no-clusters: "No clusters found";
    in property <string> i18n-create-first: "Create your first cluster to get started";

    // 回调函数
    callback add-cluster-clicked();
    callback manage-groups-clicked();
    callback group-selected(string);
    callback cluster-selected(string);
    callback cluster-edit-clicked(string);
    callback cluster-delete-clicked(string);
    callback cluster-connect-clicked(string);
    callback refresh-clusters();
    callback back-clicked();

    background: Theme.background;

    VerticalBox {
        padding: 16px;
        spacing: 16px;

        // ==================== 页面头部 ====================
        HorizontalBox {
            spacing: 16px;
            alignment: start;

            // 返回按钮
            Rectangle {
                width: 30px;
                height: 30px;
                background: Theme.background;
                border-radius: 4px;

                Text {
                    text: "←";
                    font-size: 16px;
                    color: Theme.text-secondary;
                }

                TouchArea {
                    clicked => { back-clicked(); }
                }
            }

            VerticalBox {
                alignment: start;

                // 页面标题
                HorizontalBox {
                    spacing: 8px;

                    Text {
                        text: "📊";
                        font-size: 24px;
                        color: Theme.primary;
                    }

                    Text {
                        text: i18n-title;
                        font-size: 20px;
                        font-weight: 600;
                        color: Theme.text-primary;
                    }
                }

                // 页面描述
                Text {
                    text: i18n-description;
                    font-size: 14px;
                    color: Theme.text-secondary;
                }
            }

            // 操作按钮（右侧）
            HorizontalBox {
                spacing: 8px;
                alignment: end;

                // 管理分组按钮
                Rectangle {
                    width: 120px;
                    height: 30px;
                    background: Theme.background;
                    border-radius: 4px;

                    Text {
                        text: "📁 " + i18n-add-group;
                        font-size: 12px;
                        color: Theme.text-secondary;
                    }

                    TouchArea {
                        clicked => { manage-groups-clicked(); }
                    }
                }

                // 添加集群按钮
                Rectangle {
                    width: 120px;
                    height: 30px;
                    background: Theme.primary;
                    border-radius: 4px;

                    Text {
                        text: "+ " + i18n-add-cluster;
                        font-size: 12px;
                        color: white;
                    }

                    TouchArea {
                        clicked => { add-cluster-clicked(); }
                    }
                }
            }
        }

        // ==================== 分组选择器 ====================
        if group-names.length > 0: Rectangle {
            height: 40px;
            background: Theme.surface;
            border-radius: 4px;

            HorizontalBox {
                padding: 8px;
                spacing: 8px;

                Text {
                    text: i18n-group + ":";
                    font-size: 12px;
                    font-weight: 600;
                    color: Theme.text-secondary;
                }

                // 左滚动按钮
                Rectangle {
                    width: 24px;
                    height: 24px;
                    background: Theme.background;
                    border-radius: 3px;

                    Text {
                        text: "◀";
                        font-size: 12px;
                        color: Theme.text-secondary;
                    }

                    TouchArea {
                        // TODO: 实现滚动逻辑
                    }
                }

                // 分组按钮列表（横向滚动）
                HorizontalBox {
                    spacing: 4px;

                    // All按钮
                    Rectangle {
                        width: 50px;
                        height: 24px;
                        background: selected-group == "" ? Theme.primary : Theme.background;
                        border-radius: 3px;

                        Text {
                            text: i18n-all;
                            font-size: 12px;
                            color: selected-group == "" ? white : Theme.text-secondary;
                        }

                        TouchArea {
                            clicked => { group-selected(""); }
                        }
                    }

                    // 分组按钮
                    for group-name in group-names: Rectangle {
                        width: 80px;
                        height: 24px;
                        background: selected-group == group-name ? Theme.primary : Theme.background;
                        border-radius: 3px;

                        Text {
                            text: group-name;
                            font-size: 12px;
                            color: selected-group == group-name ? white : Theme.text-secondary;
                        }

                        TouchArea {
                            clicked => { group-selected(group-name); }
                        }
                    }
                }

                // 右滚动按钮
                Rectangle {
                    width: 24px;
                    height: 24px;
                    background: Theme.background;
                    border-radius: 3px;

                    Text {
                        text: "▶";
                        font-size: 12px;
                        color: Theme.text-secondary;
                    }

                    TouchArea {
                        // TODO: 实现滚动逻辑
                    }
                }
            }
        }

        // ==================== 内容区域 ====================
        Rectangle {
            vertical-stretch: 1;  // 占据剩余空间
            background: transparent;

            // 加载状态
            if loading: VerticalBox {
                alignment: center;

                Text {
                    text: "⏳";
                    font-size: 40px;
                    color: Theme.primary;
                }

                Text {
                    text: i18n-loading;
                    font-size: 14px;
                    color: Theme.text-secondary;
                }
            }

            // 错误状态
            if !loading && error != "": VerticalBox {
                alignment: center;
                spacing: 16px;

                Text {
                    text: "⚠️";
                    font-size: 40px;
                    color: Theme.error;
                }

                Text {
                    text: i18n-connection-error;
                    font-size: 18px;
                    font-weight: 600;
                    color: Theme.text-primary;
                }

                Text {
                    text: error;
                    font-size: 14px;
                    color: Theme.text-secondary;
                }

                Rectangle {
                    width: 80px;
                    height: 30px;
                    background: Theme.primary;
                    border-radius: 4px;

                    Text {
                        text: "🔄 " + i18n-retry;
                        font-size: 12px;
                        color: white;
                    }

                    TouchArea {
                        clicked => { refresh-clusters(); }
                    }
                }
            }

            // 集群列表（Grid布局 - 响应式优化）
            if !loading && error == "" && cluster-names.length > 0: VerticalBox {
                padding: 8px;
                spacing: 16px;

                // 响应式Grid布局（根据窗口宽度自动调整列数）
                // TODO: Slint不支持真正的Grid响应式，手动调整布局

                // 第1行：最多3个卡片
                HorizontalBox {
                    spacing: 16px;

                    // 遍历集群名称，每行最多显示3个
                    // 注意：Slint不支持动态布局，需要手动分行
                    for cluster-name[idx] in cluster-names: Rectangle {
                        // 计算每个卡片的宽度（响应式）
                        width: 300px;  // 固定宽度，或者根据cluster-names.length动态调整
                        height: 180px;

                        ClusterCard {
                            cluster-name: cluster-name;
                            bootstrap-servers: "localhost:9092";  // TODO: 从数据中获取
                            status: "connected";  // TODO: 从数据中获取
                            topics-count: 10;  // TODO: 从数据中获取
                            partitions-count: 20;  // TODO: 从数据中获取
                            selected: false;  // TODO: 从数据中获取

                            edit-clicked() => { cluster-edit-clicked(cluster-name); }
                            delete-clicked() => { cluster-delete-clicked(cluster-name); }
                            connect-clicked() => { cluster-connect-clicked(cluster-name); }
                        }
                    }
                }

                // 分页提示（当集群数量 > 3时）
                if cluster-names.length > 3: HorizontalBox {
                    alignment: center;
                    spacing: 8px;

                    Text {
                        text: "Showing " + cluster-names.length + " clusters";
                        font-size: 12px;
                        color: Theme.text-secondary;
                    }

                    // 分页按钮（可选）
                    // Rectangle {
                    //     width: 24px;
                    //     height: 24px;
                    //     background: Theme.background;
                    //     border-radius: 3px;
                    //     Text { text: "◀"; font-size: 12px; color: Theme.text-secondary; }
                    // }
                }
            }

            // 空状态（无集群）
            if !loading && error == "" && cluster-names.length == 0: VerticalBox {
                alignment: center;
                spacing: 16px;

                Text {
                    text: "📊";
                    font-size: 40px;
                    color: Theme.text-secondary;
                }

                Text {
                    text: i18n-no-clusters;
                    font-size: 18px;
                    font-weight: 600;
                    color: Theme.text-primary;
                }

                Text {
                    text: i18n-create-first;
                    font-size: 14px;
                    color: Theme.text-secondary;
                }

                // 创建集群按钮
                Rectangle {
                    width: 150px;
                    height: 40px;
                    background: Theme.primary;
                    border-radius: 4px;

                    Text {
                        text: "+ " + i18n-add-cluster;
                        font-size: 14px;
                        color: white;
                    }

                    TouchArea {
                        clicked => { add-cluster-clicked(); }
                    }
                }
            }
        }
    }
}