// TopicsView完整复刻（Phase 11 Week 7-8：页面复刻）
// 完整复刻原Vue版本的 TopicsView.vue
import { Button, VerticalBox, HorizontalBox, LineEdit } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { TopicCard } from "../components/card.slint";
import { SearchBox } from "../components/search.slint";
import { Badge } from "../components/badge.slint";
import { CreateTopicModal } from "../components/modal.slint";

// ==================== TopicsView组件 ====================

export component TopicsView inherits Rectangle {
    // 数据属性
    in property <[string]> topic-names: [];  // Topic名称列表
    in property <string> cluster-name: "";  // 当前集群名称
    in property <bool> loading: false;
    in property <bool> refreshing: false;
    in property <string> search-query: "";
    in property <int> total-topics: 0;  // 总Topic数量
    in property <int> matching-topics: 0;  // 匹配的Topic数量

    // 国际化字符串
    in property <string> i18n-title: "Topics";
    in property <string> i18n-description: "Manage Kafka topics";
    in property <string> i18n-refresh: "Refresh";
    in property <string> i18n-create: "Create";
    in property <string> i18n-search: "Search...";
    in property <string> i18n-no-cluster: "No cluster selected";
    in property <string> i18n-no-topics: "No topics found";
    in property <string> i18n-create-first: "Create your first topic";
    in property <string> i18n-loading: "Loading...";

    // 回调函数
    callback back-clicked();
    callback refresh-topics();
    callback create-topic-clicked();
    callback search-changed(string);
    callback topic-selected(string);
    callback topic-messages-clicked(string);
    callback topic-config-clicked(string);

    background: Theme.background;

    VerticalBox {
        padding: 16px;
        spacing: 16px;

        // ==================== 页面头部 ====================
        HorizontalBox {
            spacing: 16px;
            alignment: start;

            // 返回按钮
            Rectangle {
                width: 30px;
                height: 30px;
                background: Theme.background;
                border-radius: 4px;

                Text {
                    text: "←";
                    font-size: 16px;
                    color: Theme.text-secondary;
                }

                TouchArea {
                    clicked => { back-clicked(); }
                }
            }

            VerticalBox {
                alignment: start;

                // 页面标题
                HorizontalBox {
                    spacing: 8px;

                    Text {
                        text: "📨";
                        font-size: 24px;
                        color: Theme.primary;
                    }

                    Text {
                        text: i18n-title;
                        font-size: 20px;
                        font-weight: 600;
                        color: Theme.text-primary;
                    }
                }

                // 页面描述（显示集群名称）
                if cluster-name != "": Text {
                    text: "Cluster: " + cluster-name;
                    font-size: 14px;
                    font-weight: 600;
                    color: Theme.text-secondary;
                }

                if cluster-name == "": Text {
                    text: i18n-description;
                    font-size: 14px;
                    color: Theme.text-secondary;
                }
            }

            // 操作按钮（右侧）
            HorizontalBox {
                spacing: 8px;
                alignment: end;

                // 刷新按钮
                Rectangle {
                    width: 80px;
                    height: 30px;
                    background: Theme.background;
                    border-radius: 4px;

                    Text {
                        text: refreshing ? "⏳ " + i18n-refresh : "🔄 " + i18n-refresh;
                        font-size: 12px;
                        color: Theme.text-secondary;
                    }

                    TouchArea {
                        enabled: !refreshing && cluster-name != "";
                        clicked => { refresh-topics(); }
                    }
                }

                // 创建Topic按钮
                Rectangle {
                    width: 80px;
                    height: 30px;
                    background: Theme.primary;
                    border-radius: 4px;

                    Text {
                        text: "+ " + i18n-create;
                        font-size: 12px;
                        color: white;
                    }

                    TouchArea {
                        enabled: cluster-name != "";
                        clicked => { create-topic-clicked(); }
                    }
                }
            }
        }

        // ==================== 内容区域 ====================
        Rectangle {
            vertical-stretch: 1;
            background: transparent;

            // 未选择集群状态
            if cluster-name == "": VerticalBox {
                alignment: center;
                spacing: 16px;

                Text {
                    text: "📊";
                    font-size: 40px;
                    color: Theme.text-secondary;
                }

                Text {
                    text: i18n-no-cluster;
                    font-size: 18px;
                    font-weight: 600;
                    color: Theme.text-primary;
                }

                Text {
                    text: "Please select a cluster from the sidebar";
                    font-size: 14px;
                    color: Theme.text-secondary;
                }
            }

            // 加载状态
            if cluster-name != "" && loading: VerticalBox {
                alignment: center;

                Text {
                    text: "⏳";
                    font-size: 40px;
                    color: Theme.primary;
                }

                Text {
                    text: i18n-loading;
                    font-size: 14px;
                    color: Theme.text-secondary;
                }
            }

            // Topic列表（有数据）
            if cluster-name != "" && !loading && topic-names.length > 0: VerticalBox {
                spacing: 8px;

                // 搜索框和统计
                HorizontalBox {
                    spacing: 8px;

                    // 搜索框
                    SearchBox {
                        query: search-query;
                        placeholder: i18n-search;

                        // TODO: 搜索回调
                    }

                    // Topic数量统计
                    Badge {
                        text: total-topics + " Topics";
                        background-color: Theme.primary;
                        size: "sm";
                    }

                    // 匹配数量（有搜索时显示）
                    if search-query != "": Badge {
                        text: matching-topics + " matching";
                        background-color: Theme.success;
                        size: "sm";
                    }
                }

                // Topic卡片列表（Grid布局）
                VerticalBox {
                    padding: 8px;
                    spacing: 8px;

                    // TODO: Slint不支持真正的Grid布局
                    // 使用HorizontalBox + VerticalBox组合模拟
                    for topic-name in topic-names: TopicCard {
                        topic-name: topic-name;
                        cluster-name: root.cluster-name;
                        partitions-count: 3;  // TODO: 从数据中获取
                        replication-factor: 1;  // TODO: 从数据中获取
                        is-internal: false;  // TODO: 从数据中获取
                        selected: false;

                        view-messages-clicked() => { topic-messages-clicked(topic-name); }
                        view-config-clicked() => { topic-config-clicked(topic-name); }
                    }
                }
            }

            // 空状态（无Topic）
            if cluster-name != "" && !loading && topic-names.length == 0: VerticalBox {
                alignment: center;
                spacing: 16px;

                Text {
                    text: "📨";
                    font-size: 40px;
                    color: Theme.text-secondary;
                }

                Text {
                    text: i18n-no-topics;
                    font-size: 18px;
                    font-weight: 600;
                    color: Theme.text-primary;
                }

                Text {
                    text: i18n-create-first;
                    font-size: 14px;
                    color: Theme.text-secondary;
                }

                // 创建Topic按钮
                Rectangle {
                    width: 150px;
                    height: 40px;
                    background: Theme.primary;
                    border-radius: 4px;

                    Text {
                        text: "+ " + i18n-create;
                        font-size: 14px;
                        color: white;
                    }

                    TouchArea {
                        clicked => { create-topic-clicked(); }
                    }
                }
            }
        }
    }
}