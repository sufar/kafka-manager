{
  "$schema": "https://schema.tauri.app/config/2/capabilities",
  "identifier": "default",
  "description": "Default capabilities for the app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-open",
    "http:default",
    "dialog:default",
    "dialog:allow-save",
    "fs:default",
    {
      "identifier": "fs:write-all",
      "allow": [{ "path": "**" }]
    }
  ]
}
