{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kafka Manager",
  "version": "1.1.35",
  "identifier": "com.kafka-manager",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:9733",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kafka Manager",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1024,
        "minHeight": 768,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": false,
    "trayIcon": null
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "appimage", "deb", "msi", "nsis"],
    "resources": [],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "both",
        "languages": ["English", "SimpChinese"]
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "files": {}
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/sufar/kafka-manager/releases/download/v{{ curr_version }}/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzNENDMjQzOEYzN0VGQzUKUldURjd6ZVBROEpNbzUzREJnVzJ2SjFWSTdYSnhqN2xMRDlvbVRrUXFkaGwxU2IyT0VLTExSQ2wK"
    }
  }
}
