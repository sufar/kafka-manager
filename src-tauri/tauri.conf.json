{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kafka Manager",
  "version": "1.0.6",
  "identifier": "com.kafka-manager",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:9733",
    "beforeDevCommand": "npm run dev --prefix ../ui",
    "beforeBuildCommand": "npm run build --prefix ../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kafka Manager",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1024,
        "minHeight": 768,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": false,
    "trayIcon": null
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "deb", "msi", "nsis"],
    "resources": [
      "../config.toml",
      "../migrations"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/sufar/kafka-manager/releases/download/v{{ curr_version }}/latest.json"
      ],
      "pubkey": ""
    }
  }
}
