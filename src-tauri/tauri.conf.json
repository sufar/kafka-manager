{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kafka Manager",
  "version": "0.1.0",
  "identifier": "com.kafka-manager",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:9733",
    "beforeDevCommand": "(cd ../ui && npm run dev)",
    "beforeBuildCommand": "(cd ../ui && npm run build)"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kafka Manager",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1024,
        "minHeight": 768,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "resources": [
      "../config.toml",
      "../migrations"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ]
  }
}
