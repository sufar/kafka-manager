                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "分区";
                        color: #7f8c8d;
                        font-size: 12px;
                    }
                    Rectangle {
                        width: 100px;
                        height: 36px;
                        background: #2c3e50;
                        border-radius: 4px;

                        TextInput {
                            text: root.view_messages_partition;
                            color: #ffffff;
                            font-size: 14px;
                        }
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "消息数量";
                        color: #7f8c8d;
                        font-size: 12px;
                    }
                    Text {
                        text: root.view_messages_count;
                        color: #ffffff;
                        font-size: 14px;
                    }
                }

                Rectangle {
                    preferred-width: 50px;
                    preferred-height: 100%;
                }

                TouchArea {
                    clicked => root.confirm_view_messages();
                    Rectangle {
                        width: 100px;
                        height: 36px;
                        background: #9b59b6;
                        border-radius: 6px;

                        Text {
                            text: "加载消息";
                            color: #ffffff;
                            font-size: 14px;
                        }
                    }
                }
            }

            // 消息过滤
            HorizontalLayout {
                spacing: 16px;

                // Key 过滤
                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "过滤 Key（可选）";
                        color: #7f8c8d;
                        font-size: 12px;
                    }
                    Rectangle {
                        width: 200px;
                        height: 36px;
                        background: #2c3e50;
                        border-radius: 4px;

                        TextInput {
                            text: root.view_messages_filter_key;
                            color: #ffffff;
                            font-size: 14px;
                        }
                    }
                }

                // Value 过滤
                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "过滤 Value（可选）";
                        color: #7f8c8d;
                        font-size: 12px;
                    }
                    Rectangle {
                        width: 300px;
                        height: 36px;
                        background: #2c3e50;
                        border-radius: 4px;

                        TextInput {
                            text: root.view_messages_filter_value;
                            color: #ffffff;
                            font-size: 14px;
                        }
                    }
                }
            }

            // 消息列表
            Rectangle {
                width: 100%;
                height: 350px;
                background: #2c3e50;
                border-radius: 4px;

                VerticalLayout {
                    spacing: 8px;
                    padding: 10px;

                    // 消息列表头
                    HorizontalLayout {
                        Text {
                            text: "Offset";
                            color: #7f8c8d;
                            font-size: 11px;
                            preferred-width: 80px;
                        }
                        Text {
                            text: "时间戳";
                            color: #7f8c8d;
                            font-size: 11px;
                            preferred-width: 180px;
                        }
                        Text {
                            text: "Key";
                            color: #7f8c8d;
                            font-size: 11px;
                            preferred-width: 120px;
                        }
                        Text {
                            text: "Value";
                            color: #7f8c8d;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        width: 100%;
                        height: 1px;
                        background: #3d4a5c;
                    }

                    // 消息内容（动态生成）
                    Rectangle {
                        width: 100%;
                        height: 300px;
                        background: transparent;

                        VerticalLayout {
                            spacing: 8px;

                            // 消息 1
                            Rectangle {
                                width: 100%;
                                height: 50px;
                                background: root.view_messages_list.length >= 1 ? #34495e : transparent;
                                visible: root.view_messages_list.length >= 1;

                                Text {
                                    text: root.view_messages_list[0];
                                    color: #ecf0f1;
                                    font-size: 11px;
                                }
                            }
                            // 消息 2
                            Rectangle {
                                width: 100%;
                                height: 50px;
                                background: root.view_messages_list.length >= 2 ? #2c3e50 : transparent;
                                visible: root.view_messages_list.length >= 2;

                                Text {
                                    text: root.view_messages_list[1];
                                    color: #ecf0f1;
                                    font-size: 11px;
                                }
                            }
                            // 消息 3
                            Rectangle {
                                width: 100%;
                                height: 50px;
                                background: root.view_messages_list.length >= 3 ? #34495e : transparent;
                                visible: root.view_messages_list.length >= 3;

                                Text {
                                    text: root.view_messages_list[2];
                                    color: #ecf0f1;
                                    font-size: 11px;
                                }
                            }
                            // 消息 4
                            Rectangle {
                                width: 100%;
                                height: 50px;
                                background: root.view_messages_list.length >= 4 ? #2c3e50 : transparent;
                                visible: root.view_messages_list.length >= 4;

                                Text {
                                    text: root.view_messages_list[3];
                                    color: #ecf0f1;
                                    font-size: 11px;
                                }
                            }
                            // 消息 5
                            Rectangle {
                                width: 100%;
                                height: 50px;
                                background: root.view_messages_list.length >= 5 ? #34495e : transparent;
                                visible: root.view_messages_list.length >= 5;

                                Text {
                                    text: root.view_messages_list[4];
                                    color: #ecf0f1;
                                    font-size: 11px;
                                }
                            }
                            // 消息 6
                            Rectangle {
                                width: 100%;
                                height: 50px;
                                background: root.view_messages_list.length >= 6 ? #2c3e50 : transparent;
                                visible: root.view_messages_list.length >= 6;

                                Text {
                                    text: root.view_messages_list[5];
                                    color: #ecf0f1;
                                    font-size: 11px;
                                }
                            }
                            // 消息 7
                            Rectangle {
                                width: 100%;
                                height: 50px;
                                background: root.view_messages_list.length >= 7 ? #34495e : transparent;
                                visible: root.view_messages_list.length >= 7;

                                Text {
                                    text: root.view_messages_list[6];
                                    color: #ecf0f1;
                                    font-size: 11px;
                                }
                            }
                            // 消息 8
                            Rectangle {
                                width: 100%;
                                height: 50px;
                                background: root.view_messages_list.length >= 8 ? #2c3e50 : transparent;
                                visible: root.view_messages_list.length >= 8;

                                Text {
                                    text: root.view_messages_list[7];
                                    color: #ecf0f1;
                                    font-size: 11px;
                                }
                            }
                            // 消息 9
                            Rectangle {
                                width: 100%;
                                height: 50px;
                                background: root.view_messages_list.length >= 9 ? #34495e : transparent;
                                visible: root.view_messages_list.length >= 9;

                                Text {
                                    text: root.view_messages_list[8];
                                    color: #ecf0f1;
                                    font-size: 11px;
                                }
                            }
                            // 消息 10
                            Rectangle {
                                width: 100%;
                                height: 50px;
                                background: root.view_messages_list.length >= 10 ? #2c3e50 : transparent;
                                visible: root.view_messages_list.length >= 10;

                                Text {
                                    text: root.view_messages_list[9];
                                    color: #ecf0f1;
                                    font-size: 11px;
                                }
                            }

                            // 空状态
                            Rectangle {
                                width: 100%;
                                height: 100px;
                                background: transparent;
                                visible: root.view_messages_list.length == 0;

                                VerticalLayout {
                                    alignment: center;

                                    Text {
                                        text: "暂无消息";
                                        color: #5d6d7e;
                                        font-size: 13px;
                                    }
                                }
                            }
                        }
                    }
                }

                // 空状态
                Rectangle {
                    width: 100%;
                    height: 100px;
                    background: transparent;
                    visible: root.view_messages_list.length == 0;

                    VerticalLayout {
                        alignment: center;

                        Text {
                            text: "暂无消息";
                            color: #5d6d7e;
                            font-size: 13px;
                        }
                    }
                }
            }
        }

        // 关闭按钮
        HorizontalLayout {
            alignment: center;
            spacing: 12px;

            Rectangle {
                preferred-width: 500px;
                preferred-height: 100%;
            }

            TouchArea {
                clicked => root.close_view_messages_dialog();
                Rectangle {
                    width: 100px;
                    height: 36px;
                    background: #34495e;
                    border-radius: 6px;

                    Text {
                        text: "关闭";
                        color: #ffffff;
                        font-size: 14px;
                    }
                }
            }
        }
    }

    // 重置 Consumer Group offset 弹窗
    Rectangle {
        width: 450px;
        height: 380px;
        background: #1e2a3a;
        border-radius: 10px;
        visible: root.show_reset_offset_dialog;

        VerticalLayout {
            padding: 20px;
            spacing: 16px;

            // 标题
            HorizontalLayout {
                Text {
                    text: "重置 Consumer Group Offset";
                    color: #ffffff;
                    font-size: 18px;
                }
                Rectangle {
                    preferred-width: 120px;
                    preferred-height: 100%;
                }
                TouchArea {
                    clicked => root.close_reset_offset_dialog();
                    Rectangle {
                        width: 30px;
                        height: 30px;
                        background: #e74c3c;
                        border-radius: 5px;

                        Text {
                            text: "×";
                            color: #ffffff;
                            font-size: 20px;
                        }
                    }
                }
            }

            Rectangle {
                width: 100%;
                height: 1px;
                background: #3d4a5c;
            }

            // Group 名称
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "Consumer Group";
                    color: #7f8c8d;
                    font-size: 12px;
                }
                Text {
                    text: root.reset_offset_group;
                    color: #ffffff;
                    font-size: 14px;
                }
            }

            // Topic
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "Topic";
                    color: #7f8c8d;
                    font-size: 12px;
                }
                Text {
                    text: root.reset_offset_topic;
                    color: #ffffff;
                    font-size: 14px;
                }
            }

            // 分区
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "分区";
                    color: #7f8c8d;
                    font-size: 12px;
                }
                Rectangle {
                    width: 100%;
                    height: 36px;
                    background: #2c3e50;
                    border-radius: 4px;

                    TextInput {
                        text: root.reset_offset_partition;
                        color: #ffffff;
                        font-size: 14px;
                    }
                }
            }

            // 重置模式
            VerticalLayout {
                spacing: 8px;
                Text {
                    text: "重置到";
                    color: #7f8c8d;
                    font-size: 12px;
                }

                // Earliest
                TouchArea {
                    clicked => { root.reset_offset_mode = 0; root.on_reset_offset_mode_changed(0); }
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            width: 16px;
                            height: 16px;
                            border-radius: 8px;
                            background: root.reset_offset_mode == 0 ? #3498db : #34495e;
                        }
                        Text {
                            text: "最早的消息 (Earliest)";
                            color: #ffffff;
                            font-size: 13px;
                        }
                    }
                }

                // Latest
                TouchArea {
                    clicked => { root.reset_offset_mode = 1; root.on_reset_offset_mode_changed(1); }
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            width: 16px;
                            height: 16px;
                            border-radius: 8px;
                            background: root.reset_offset_mode == 1 ? #3498db : #34495e;
                        }
                        Text {
                            text: "最新的消息 (Latest)";
                            color: #ffffff;
                            font-size: 13px;
                        }
                    }
                }

                // Specific
                TouchArea {
                    clicked => { root.reset_offset_mode = 2; root.on_reset_offset_mode_changed(2); }
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            width: 16px;
                            height: 16px;
                            border-radius: 8px;
                            background: root.reset_offset_mode == 2 ? #3498db : #34495e;
                        }
                        Text {
                            text: "指定 Offset";
                            color: #ffffff;
                            font-size: 13px;
                        }
                    }
                }

                // 指定 Offset 输入
                Rectangle {
                    width: 100%;
                    height: 36px;
                    background: #2c3e50;
                    border-radius: 4px;
                    visible: root.reset_offset_mode == 2;

                    TextInput {
                        text: root.reset_offset_specific;
                        color: #ffffff;
                        font-size: 14px;
                    }
                }
            }

            Rectangle {
                preferred-width: 100%;
                preferred-height: 20px;
            }

            // 按钮
            HorizontalLayout {
                alignment: center;
                spacing: 12px;

                Rectangle {
                    preferred-width: 150px;
                    preferred-height: 100%;
                }

                TouchArea {
                    clicked => root.close_reset_offset_dialog();
                    Rectangle {
                        width: 100px;
                        height: 36px;
                        background: #34495e;
                        border-radius: 6px;

                        Text {
                            text: "取消";
                            color: #ffffff;
                            font-size: 14px;
                        }
                    }
                }

                TouchArea {
                    clicked => root.confirm_reset_offset();
                    Rectangle {
                        width: 100px;
                        height: 36px;
                        background: #f39c12;
                        border-radius: 6px;

                        Text {
                            text: "确认";
                            color: #ffffff;
                            font-size: 14px;
                        }
                    }
                }
            }
        }
    }

    // 集群配置管理弹窗
    Rectangle {
        width: 500px;
        height: 400px;
        background: #1e2a3a;
        border-radius: 10px;
        visible: root.show_cluster_config_dialog;

        VerticalLayout {
            padding: 20px;
            spacing: 16px;

            // 标题
            HorizontalLayout {
                Text {
                    text: "集群配置管理";
                    color: #ffffff;
                    font-size: 18px;
                }
                Rectangle {
                    preferred-width: 300px;
                    preferred-height: 100%;
                }
                TouchArea {
                    clicked => root.close_cluster_config_dialog();
                    Rectangle {
                        width: 30px;
                        height: 30px;
                        background: #e74c3c;
                        border-radius: 5px;

                        Text {
                            text: "×";
                            color: #ffffff;
                            font-size: 20px;
                        }
                    }
                }
            }

            Rectangle {
                width: 100%;
                height: 1px;
                background: #3d4a5c;
            }

            // 集群名称
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "集群名称";
                    color: #7f8c8d;
                    font-size: 12px;
                }
                Rectangle {
                    width: 100%;
                    height: 40px;
                    background: #2c3e50;
                    border-radius: 4px;

                    TextInput {
                        text: root.cluster_config_name;
                        color: #ffffff;
                        font-size: 14px;
                    }
                }
            }

            // Brokers 地址
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "Brokers 地址";
                    color: #7f8c8d;
                    font-size: 12px;
                }
                Rectangle {
                    width: 100%;
                    height: 40px;
                    background: #2c3e50;
                    border-radius: 4px;

                    TextInput {
                        text: root.cluster_config_brokers;
                        color: #ffffff;
                        font-size: 14px;
                    }
                }
            }

            // SASL 用户名（可选）
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "SASL 用户名（可选）";
                    color: #7f8c8d;
                    font-size: 12px;
                }
                Rectangle {
                    width: 100%;
                    height: 40px;
                    background: #2c3e50;
                    border-radius: 4px;

                    TextInput {
                        text: root.cluster_config_sasl_username;
                        color: #ffffff;
                        font-size: 14px;
                    }
                }
            }

            // SASL 密码（可选）
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "SASL 密码（可选）";
                    color: #7f8c8d;
                    font-size: 12px;
                }
                Rectangle {
                    width: 100%;
                    height: 40px;
                    background: #2c3e50;
                    border-radius: 4px;

                    TextInput {
                        text: root.cluster_config_sasl_password;
                        color: #ffffff;
                        font-size: 14px;
                    }
                }
            }

            Rectangle {
                preferred-width: 100%;
                preferred-height: 1px;
            }

            // 按钮
            HorizontalLayout {
                alignment: center;
                spacing: 12px;

                Rectangle {
                    preferred-width: 200px;
                    preferred-height: 100%;
                }

                TouchArea {
                    clicked => root.close_cluster_config_dialog();
                    Rectangle {
                        width: 100px;
                        height: 36px;
                        background: #34495e;
                        border-radius: 6px;

                        Text {
                            text: "取消";
                            color: #ffffff;
                            font-size: 14px;
                        }
                    }
                }

                TouchArea {
                    clicked => root.confirm_save_cluster_config();
                    Rectangle {
                        width: 100px;
                        height: 36px;
                        background: #27ae60;
                        border-radius: 6px;

                        Text {
                            text: "保存";
                            color: #ffffff;
                            font-size: 14px;
                        }
                    }
                }
            }
        }
    }

    // 发送消息弹窗
    Rectangle {
        width: 500px;
        height: 450px;
        background: #1e2a3a;
        border-radius: 10px;
        visible: root.show_send_message_dialog;

        VerticalLayout {
            padding: 20px;
            spacing: 16px;

            // 标题
            HorizontalLayout {
                Text {
                    text: "发送消息";
                    color: #ffffff;
                    font-size: 18px;
                }
                Rectangle {
                    preferred-width: 320px;
                    preferred-height: 100%;
                }
                TouchArea {
                    clicked => root.close_send_message_dialog();
                    Rectangle {
                        width: 30px;
                        height: 30px;
                        background: #e74c3c;
                        border-radius: 5px;

                        Text {
                            text: "×";
                            color: #ffffff;
                            font-size: 20px;
                        }
                    }
                }
            }

            Rectangle {
                width: 100%;
                height: 1px;
                background: #3d4a5c;
            }

            // Topic 名称
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "Topic";
                    color: #7f8c8d;
                    font-size: 12px;
                }
                Text {
                    text: root.send_message_topic;
                    color: #ffffff;
                    font-size: 14px;
                }
            }

            // 分区选择
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "分区";
                    color: #7f8c8d;
                    font-size: 12px;
                }
                Rectangle {
                    width: 100%;
                    height: 40px;
                    background: #2c3e50;
                    border-radius: 4px;

                    TextInput {
                        text: root.send_message_partition;
                        color: #ffffff;
                        font-size: 14px;
                    }
                }
            }

            // 消息 Key（可选）
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "消息 Key（可选）";
                    color: #7f8c8d;
                    font-size: 12px;
                }
                Rectangle {
                    width: 100%;
                    height: 40px;
                    background: #2c3e50;
                    border-radius: 4px;

                    TextInput {
                        text: root.send_message_key;
                        color: #ffffff;
                        font-size: 14px;
                    }
                }
            }

            // 消息 Value
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: "消息 Value";
                    color: #7f8c8d;
                    font-size: 12px;
                }
                Rectangle {
                    width: 100%;
                    height: 80px;
                    background: #2c3e50;
                    border-radius: 4px;

                    TextInput {
                        text: root.send_message_value;
                        color: #ffffff;
                        font-size: 14px;
                        vertical-alignment: top;
                    }
                }
            }

            // 结果显示
            Rectangle {
                width: 100%;
                height: 50px;
                background: #2c3e50;
                border-radius: 4px;
                visible: root.send_message_result != "";

                Text {
                    text: root.send_message_result;
                    color: #2ecc71;
                    font-size: 12px;
                }
            }

            // 按钮
            HorizontalLayout {
                alignment: center;
                spacing: 12px;

                Rectangle {
                    preferred-width: 200px;
                    preferred-height: 100%;
                }

                TouchArea {
                    clicked => root.close_send_message_dialog();
                    Rectangle {
                        width: 100px;
                        height: 36px;
                        background: #34495e;
                        border-radius: 6px;

                        Text {
                            text: "取消";
                            color: #ffffff;
                            font-size: 14px;
                        }
                    }
                }

                TouchArea {
                    clicked => root.confirm_send_message();
                    Rectangle {
                        width: 100px;
                        height: 36px;
                        background: #27ae60;
                        border-radius: 6px;

                        Text {
                            text: "发送";
                            color: #ffffff;
                            font-size: 14px;
                        }
                    }
                }
            }
        }
    }
}
